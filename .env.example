# Neon PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_SSL_MODE=require

# Yunwu (text + image)
YUNWU_API_KEY=your_yunwu_api_key
YUNWU_BASE_URL=https://yunwu.ai/v1
TEXT_MODEL=gpt-4o-mini
IMAGE_MODEL=gemini-3.1-flash-image-preview

# Volcengine Ark (video)
ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seedance-1-0-pro-fast-251015

# Object Storage for image URL persistence (S3 compatible: AWS S3 / Cloudflare R2 / MinIO)
OBJECT_STORAGE_BUCKET=your_bucket
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ENDPOINT=https://<account-or-s3-endpoint>
OBJECT_STORAGE_ACCESS_KEY_ID=your_access_key
OBJECT_STORAGE_SECRET_ACCESS_KEY=your_secret_key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://<public-domain-or-endpoint>/<bucket-optional>
OBJECT_STORAGE_PREFIX=generated-images
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Optional
PORT=3000
VIDEO_POLL_INTERVAL_MS=5000
VIDEO_POLL_MAX_ROUNDS=60
